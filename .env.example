# Agent config — copy to .env on each remote machine and run `pnpm agent`.
#
# SERVER_URL: where the dashboard is reachable. Over Tailscale, use the
# MagicDNS name of the server (e.g. http://home-pc.tailnet.ts.net:3000)
# so the URL is stable when IPs change.
SERVER_URL=http://home-pc.tailnet.ts.net:3000

# API_KEY: bearer token shown on the dashboard's Settings page under
# "Remote ingest". Regenerating on the server invalidates every agent.
API_KEY=replace-with-key-from-settings-page

# MACHINE_ID: human-readable label for this machine, shown in the
# dashboard's machine filter. Defaults to `os.hostname()`.
# MACHINE_ID=laptop

# CLAUDE_DIR: where Claude Code stores its session logs. Rarely needs
# overriding. Defaults to ~/.claude/projects.
# CLAUDE_DIR=

# STATE_FILE: per-file offset tracking so the agent resumes across
# restarts. Defaults to ~/.claude-usage-agent-state.json.
# STATE_FILE=
